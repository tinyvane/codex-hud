{
  "name": "codex-hud",
  "version": "0.1.3",
  "description": "Heads-up display for OpenAI Codex",
  "license": "MIT",
  "author": "tinyvane",
  "homepage": "https://github.com/tinyvane/codex-hud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyvane/codex-hud.git"
  },
  "bugs": {
    "url": "https://github.com/tinyvane/codex-hud/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0 <11.0.0"
  },
  "bin": {
    "codex-hud": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:core && pnpm run build:plugin",
    "build:core": "tsc -p tsconfig.build.json",
    "build:plugin": "node scripts/build-plugin.mjs",
    "audit:security": "pnpm audit --registry=https://registry.npmjs.org --audit-level high",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm validate:plugin",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src tests scripts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"plugins/**/*.json\" \".agents/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"plugins/**/*.json\" \".agents/**/*.json\"",
    "validate:plugin": "node scripts/validate-plugin.mjs"
  },
  "dependencies": {
    "smol-toml": "^1.3.1",
    "ws": "^8.18.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^20.19.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^3.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
